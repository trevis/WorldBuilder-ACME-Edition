<Window
    x:Class="WorldBuilder.Views.ExportDatsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialog="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:WorldBuilder.ViewModels"
    Title="Export Dats"
    Width="520"
    Height="600"
    x:DataType="vm:ExportDatsWindowViewModel"
    Background="#0d0016"
    RequestedThemeVariant="Dark"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <dialog:DialogHost Identifier="ExportDialogHost">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Form Content  -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="600" Spacing="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,5"
                            FontWeight="SemiBold"
                            Text="Export Directory *" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox
                                Grid.Column="0"
                                Classes.error="{Binding HasDirectoryError}"
                                Text="{Binding ExportDirectory}"
                                Watermark="Select directory to export DAT files..." />
                            <Button
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Padding="15,5"
                                Command="{Binding BrowseExportDirectoryCommand}"
                                Content="Browse..." />
                        </Grid>
                        <TextBlock
                            Classes.error="{Binding HasDirectoryError}"
                            IsVisible="{Binding HasDirectoryError}"
                            Text="{Binding DirectoryErrorMessage}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,5"
                            FontWeight="SemiBold"
                            Text="Portal Iteration *" />
                        <TextBox
                            Classes.error="{Binding HasIterationError}"
                            Text="{Binding PortalIteration}"
                            Watermark="Portal Iteration" />
                        <TextBlock
                            Classes.error="{Binding HasIterationError}"
                            IsVisible="{Binding HasIterationError}"
                            Text="{Binding IterationErrorMessage}" />
                    </StackPanel>

                    <StackPanel>
                        <CheckBox
                            Margin="0,10,0,0"
                            Content="Overwrite existing DAT files"
                            IsChecked="{Binding OverwriteFiles}" />
                    </StackPanel>

                    <!-- ACE Database Instance Reposition -->
                    <Border
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,4,0,0">
                        <StackPanel Spacing="10">
                            <CheckBox
                                Content="Reposition DB instances after export"
                                IsChecked="{Binding EnableReposition}"
                                FontWeight="SemiBold" />

                            <StackPanel
                                Spacing="8"
                                IsVisible="{Binding EnableReposition}">

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="MySQL Host" Margin="0,0,0,3" />
                                        <TextBox Text="{Binding DbHost}" Watermark="localhost" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" MinWidth="80">
                                        <TextBlock Text="Port" Margin="0,0,0,3" />
                                        <TextBox Text="{Binding DbPort}" Watermark="3306" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel>
                                    <TextBlock Text="Database" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding DbDatabase}" Watermark="ace_world" />
                                </StackPanel>

                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="User" Margin="0,0,0,3" />
                                        <TextBox Text="{Binding DbUser}" Watermark="root" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Password" Margin="0,0,0,3" />
                                        <TextBox Text="{Binding DbPassword}"
                                                 PasswordChar="*"
                                                 Watermark="password" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel>
                                    <TextBlock Text="Min Height Delta Threshold" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding RepositionThreshold}" Watermark="0.05" />
                                </StackPanel>

                                <CheckBox
                                    Content="Apply changes directly to database"
                                    IsChecked="{Binding ApplyDirectly}" />

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button
                                        Content="Test Connection"
                                        Command="{Binding TestConnectionCommand}"
                                        Padding="10,5" />
                                </StackPanel>
                                <TextBlock
                                    IsVisible="{Binding HasConnectionTestResult}"
                                    Text="{Binding ConnectionTestResult}"
                                    Foreground="#aaa"
                                    TextWrapping="Wrap"
                                    FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--  Navigation Buttons  -->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    MinWidth="100"
                    Padding="20,10"
                    HorizontalContentAlignment="Center"
                    Click="Cancel_Click"
                    Content="Cancel" />

                <Button
                    Grid.Column="2"
                    MinWidth="100"
                    Padding="20,10"
                    HorizontalContentAlignment="Center"
                    Classes="accent"
                    Click="Export_Click"
                    Content="Export"
                    IsEnabled="{Binding CanExport}" />
            </Grid>
        </Grid>
    </dialog:DialogHost>
</Window>
