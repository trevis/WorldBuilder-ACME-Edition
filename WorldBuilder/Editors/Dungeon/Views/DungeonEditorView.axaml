<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:WorldBuilder.Editors.Dungeon"
             xmlns:local="using:WorldBuilder.Editors.Dungeon.Views"
             xmlns:dh="using:DialogHostAvalonia"
             xmlns:docking="clr-namespace:WorldBuilder.Lib.Docking;assembly=WorldBuilder"
             xmlns:dockingViews="clr-namespace:WorldBuilder.Lib.Docking.Views;assembly=WorldBuilder"
             xmlns:converters="clr-namespace:WorldBuilder.Lib.Converters;assembly=WorldBuilder"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="WorldBuilder.Editors.Dungeon.Views.DungeonEditorView"
             x:DataType="vm:DungeonEditorViewModel"
             DragDrop.AllowDrop="True">

    <UserControl.Resources>
        <converters:OrientationToColumnsConverter x:Key="OrientationToColumns" />
        <converters:OrientationToRowsConverter x:Key="OrientationToRows" />

        <DataTemplate x:Key="DockTabContentTemplate" x:DataType="docking:DockablePanelViewModel">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="2,2" BorderBrush="#2a1d42" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#1a0e30" />
                            <GradientStop Offset="1" Color="#16102a" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="1">
                        <Button Classes="dng-toolbar-btn" ToolTip.Tip="Move to Dock" Foreground="#5a4a6e" FontSize="11" Padding="4,2">
                            <TextBlock Text="&#x2630;" FontSize="11" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="Dock Left"   Command="{Binding DockToCommand}" CommandParameter="Left" />
                                    <MenuItem Header="Dock Right"  Command="{Binding DockToCommand}" CommandParameter="Right" />
                                    <MenuItem Header="Dock Top"    Command="{Binding DockToCommand}" CommandParameter="Top" />
                                    <MenuItem Header="Dock Bottom" Command="{Binding DockToCommand}" CommandParameter="Bottom" />
                                    <Separator />
                                    <MenuItem Header="Center"      Command="{Binding DockToCommand}" CommandParameter="Center" />
                                    <MenuItem Header="Float"       Command="{Binding FloatCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Classes="dng-toolbar-btn" Content="&#x25C0;" ToolTip.Tip="Move Tab Left" Command="{Binding MoveUpCommand}" FontSize="9" Padding="4,2" />
                        <Button Classes="dng-toolbar-btn" Content="&#x25B6;" ToolTip.Tip="Move Tab Right" Command="{Binding MoveDownCommand}" FontSize="9" Padding="4,2" />
                        <Button Classes="dng-toolbar-btn" Content="&#x2715;" ToolTip.Tip="Close" Command="{Binding CloseCommand}" Foreground="#cc6666" FontSize="9" Padding="4,2" />
                    </StackPanel>
                </Border>
                <ContentControl Content="{Binding Content}" />
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.dng-toolbar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="#8a7a9e" />
        </Style>
        <Style Selector="Button.dng-toolbar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33ffffff" />
            <Setter Property="Foreground" Value="#c0b0d8" />
        </Style>
        <Style Selector="TabControl.dock-tabs">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl.dock-tabs > TabItem">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Foreground" Value="#8a7a9e" />
        </Style>
        <Style Selector="TabControl.dock-tabs > TabItem:selected">
            <Setter Property="Foreground" Value="#c0b0d8" />
        </Style>
    </UserControl.Styles>

    <dh:DialogHost Identifier="DungeonDialogHost"
                   DialogMargin="0"
                   CloseOnClickAway="True"
                   OverlayBackground="#80000000">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Background="#120c22"
                    BorderBrush="#2a1d42"
                    BorderThickness="0,0,0,1"
                    Padding="4,2">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" DockPanel.Dock="Left">
                        <Button Classes="dng-toolbar-btn" Content="Open Dungeon..." Command="{Binding OpenLandblockCommand}" />
                        <Button Classes="dng-toolbar-btn" Content="New Dungeon..." Command="{Binding NewDungeonCommand}" />
                        <Button Classes="dng-toolbar-btn" Content="Save" Command="{Binding SaveDungeonCommand}" Foreground="#6ec07a" />
                        <Button Classes="dng-toolbar-btn" Content="Compute Visibility" Command="{Binding ComputeVisibilityCommand}" Foreground="#4dbd7c"
                                ToolTip.Tip="Compute VisibleCells (stab lists) for all cells via BFS through portals." />
                        <Button Classes="dng-toolbar-btn" Content="Validate" Command="{Binding ValidateDungeonCommand}" Foreground="#bd974d"
                                ToolTip.Tip="Run comprehensive validation checks." />
                        <Button Classes="dng-toolbar-btn" Content="Generate..." Command="{Binding GenerateDungeonCommand}" Foreground="#4dbdbd"
                                ToolTip.Tip="Build a new dungeon using proven room connections from real game data." />
                        <Border Width="1" Background="#2a1d42" Margin="4,2" />
                        <CheckBox IsChecked="{Binding ShowConnectionLines}" Content="Show connections" FontSize="11" Foreground="#8a7a9e" VerticalAlignment="Center" />
                        <CheckBox IsChecked="{Binding ShowPortalIndicators}" Content="Show doorways" FontSize="11" Foreground="#8a7a9e" VerticalAlignment="Center" />
                        <Button Classes="dng-toolbar-btn" Content="{Binding CameraModeText}" Command="{Binding ToggleCameraModeCommand}" ToolTip.Tip="Toggle between perspective and top-down view" />
                        <Border Width="1" Background="#2a1d42" Margin="4,2" />
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Foreground="#8a7a9e" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding CurrentPositionText}" VerticalAlignment="Center" FontSize="11" Foreground="#5a4a6e" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Top Panels (dockable) -->
            <Border Grid.Row="1" Background="#0e0a1a" BorderBrush="#2a1d42" BorderThickness="0,0,0,1"
                    MaxHeight="300" IsVisible="{Binding DockingManager.TopPanels.Count}">
                <TabControl Classes="dock-tabs"
                            ItemsSource="{Binding DockingManager.TopPanels}"
                            ContentTemplate="{StaticResource DockTabContentTemplate}">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="docking:IDockable">
                            <TextBlock Text="{Binding Title}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
            </Border>

            <!-- Main content area -->
            <Grid x:Name="MainGrid" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="500" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" MinWidth="180" MaxWidth="500" />
                </Grid.ColumnDefinitions>

                <!-- Left Panels (dockable) -->
                <Border Grid.Column="0" Background="#0e0a1a" BorderBrush="#2a1d42" BorderThickness="0,0,1,0"
                        IsVisible="{Binding DockingManager.LeftPanels.Count}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="2,1" Background="#16102a" BorderBrush="#2a1d42" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Classes="dng-toolbar-btn" Content="&#x25A4;" FontSize="9" Padding="4,2"
                                        ToolTip.Tip="Toggle Tabbed/Sections"
                                        Command="{Binding DockingManager.ToggleLeftModeCommand}" />
                            </StackPanel>
                        </Border>
                        <TabControl Classes="dock-tabs"
                                    IsVisible="{Binding DockingManager.IsLeftTabbed}"
                                    ItemsSource="{Binding DockingManager.LeftPanels}"
                                    ContentTemplate="{StaticResource DockTabContentTemplate}">
                            <TabControl.ItemTemplate>
                                <DataTemplate x:DataType="docking:IDockable">
                                    <TextBlock Text="{Binding Title}" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>
                        <ItemsControl IsVisible="{Binding DockingManager.IsLeftSectioned}"
                                      ItemsSource="{Binding DockingManager.LeftPanels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="0" Columns="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="docking:DockablePanelViewModel">
                                    <docking:DockablePanelView />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" Background="#2a1d42" />

                <!-- Center: 3D Viewport -->
                <Grid Grid.Column="2">
                    <local:DungeonViewportControl />

                    <!-- Placement mode overlay at top of viewport -->
                    <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                            Margin="0,8,0,0" Padding="16,8" CornerRadius="6"
                            Background="#DD0a3040" BorderBrush="#4dbdbd" BorderThickness="1"
                            IsVisible="{Binding IsPlacementMode}" IsHitTestVisible="False">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PlacementStatusText}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#4dbdbd" HorizontalAlignment="Center" />
                            <TextBlock Text="Click near a green doorway to attach  |  Escape to cancel"
                                       FontSize="11" Foreground="#6a8a8a" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Empty state -->
                    <Border Background="#CC0a0614" IsVisible="{Binding !HasDungeon}" IsHitTestVisible="True">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                            <TextBlock Text="Get started" FontSize="20" FontWeight="SemiBold" Foreground="#8a7a9e" HorizontalAlignment="Center" />
                            <TextBlock Text="Open an existing dungeon to edit, or create a new one and place rooms from the palette."
                                       FontSize="12" Foreground="#5a4a6e" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                <Button Content="Open Dungeon..." Command="{Binding OpenLandblockCommand}" Classes="dng-toolbar-btn" Padding="16,10" FontSize="13" />
                                <Button Content="Start from template..." Command="{Binding StartFromTemplateCommand}" Classes="dng-toolbar-btn" Padding="16,10" FontSize="13" Foreground="#7c4dbd" />
                                <Button Content="New Dungeon..." Command="{Binding NewDungeonCommand}" Classes="dng-toolbar-btn" Padding="16,10" FontSize="13" />
                                <Button Content="Generate..." Command="{Binding GenerateDungeonCommand}" Classes="dng-toolbar-btn" Padding="16,10" FontSize="13" Foreground="#4dbdbd" />
                            </StackPanel>
                            <TextBlock Text="Pick rooms from the catalog on the left to build your dungeon piece by piece."
                                       FontSize="11" Foreground="#4a3a5e" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3" Width="4" Background="#2a1d42" />

                <!-- Right Panel: Tools (dockable) + Cell Properties (fixed) -->
                <Border Grid.Column="4" Background="#0e0a1a" BorderBrush="#2a1d42" BorderThickness="1,0,0,0">
                    <DockPanel>
                        <!-- Dockable right panels (Tools) -->
                        <Border DockPanel.Dock="Top"
                                IsVisible="{Binding DockingManager.RightPanels.Count}">
                            <TabControl Classes="dock-tabs"
                                        ItemsSource="{Binding DockingManager.RightPanels}"
                                        ContentTemplate="{StaticResource DockTabContentTemplate}"
                                        MaxHeight="350">
                                <TabControl.ItemTemplate>
                                    <DataTemplate x:DataType="docking:IDockable">
                                        <TextBlock Text="{Binding Title}" />
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                            </TabControl>
                        </Border>

                        <!-- Room Properties (always visible below tools) -->
                        <Border>
                            <Grid>
                                <local:CellPropertiesView DataContext="{Binding}" IsVisible="{Binding HasSelectedCell}" />
                                <TextBlock Text="Select a room to view properties"
                                           FontSize="11" Foreground="#5a4a6e"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           IsVisible="{Binding !HasSelectedCell}" />
                            </Grid>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Bottom Panels (dockable) -->
            <GridSplitter Grid.Row="3" Height="4" Background="#2a1d42"
                          IsVisible="{Binding DockingManager.BottomPanels.Count}" />
            <Border Grid.Row="4" Background="#0e0a1a" BorderBrush="#2a1d42" BorderThickness="0,1,0,0"
                    MaxHeight="300" IsVisible="{Binding DockingManager.BottomPanels.Count}">
                <TabControl Classes="dock-tabs"
                            ItemsSource="{Binding DockingManager.BottomPanels}"
                            ContentTemplate="{StaticResource DockTabContentTemplate}">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="docking:IDockable">
                            <TextBlock Text="{Binding Title}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
            </Border>

            <!-- Status Bar overlay at bottom of viewport row -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Background="#DD120c22" BorderBrush="#2a1d42" BorderThickness="0,1,0,0" Padding="10,4"
                    IsHitTestVisible="False">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="#8a7a9e" VerticalAlignment="Center" Text="Dungeon Editor" />
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="11" Foreground="#5a4a6e" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Rooms: {0}">
                                <Binding Path="CellCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#6a5a7e" VerticalAlignment="Center" Margin="20,0,0,0"
                               IsVisible="{Binding ShowHoveredCellInfo}" Text="{Binding HoveredCellInfo}" />
                    <TextBlock FontSize="11" Foreground="#7c4dbd" VerticalAlignment="Center" Margin="20,0,0,0"
                               IsVisible="{Binding HasSelectedCell}" Text="{Binding SelectedCellInfo}" />
                </DockPanel>
            </Border>

            <!-- Drop ghosts for drag-to-dock -->
            <Border Name="LeftGhost" Grid.Row="0" Grid.RowSpan="5" HorizontalAlignment="Left" Width="200"
                    Background="#4400aaff" IsVisible="False" IsHitTestVisible="False" />
            <Border Name="RightGhost" Grid.Row="0" Grid.RowSpan="5" HorizontalAlignment="Right" Width="200"
                    Background="#4400aaff" IsVisible="False" IsHitTestVisible="False" />
            <Border Name="TopGhost" Grid.Row="0" Grid.RowSpan="5" VerticalAlignment="Top" Height="150"
                    Background="#4400aaff" IsVisible="False" IsHitTestVisible="False" />
            <Border Name="BottomGhost" Grid.Row="0" Grid.RowSpan="5" VerticalAlignment="Bottom" Height="150"
                    Background="#4400aaff" IsVisible="False" IsHitTestVisible="False" />
        </Grid>
    </dh:DialogHost>
</UserControl>
