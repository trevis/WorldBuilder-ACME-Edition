<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:WorldBuilder.Editors.Dungeon"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="600"
             x:Class="WorldBuilder.Editors.Dungeon.Views.RoomPaletteView"
             x:DataType="vm:RoomPaletteViewModel">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#16102a"
                BorderBrush="#2a1d42"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <TextBlock Text="Dungeon Pieces"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#c0b0d8" />
        </Border>

        <!-- Search -->
        <Border DockPanel.Dock="Top" Padding="6,4">
            <TextBox Text="{Binding SearchText}"
                     Watermark="Search pieces..."
                     FontSize="11" />
        </Border>

        <!-- Category filter -->
        <Border DockPanel.Dock="Top" Padding="6,2">
            <Grid ColumnDefinitions="*,Auto">
                <ComboBox Grid.Column="0" ItemsSource="{Binding CatalogCategories}"
                          SelectedItem="{Binding CatalogCategory}"
                          FontSize="11" HorizontalAlignment="Stretch" />
                <CheckBox Grid.Column="1" IsChecked="{Binding ShowCompatibleOnly}"
                          Content="Compatible" FontSize="10" Foreground="#6ec07a"
                          ToolTip.Tip="Only show pieces that connect to your dungeon's open doorways"
                          Margin="6,0,0,0" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Status -->
        <Border DockPanel.Dock="Bottom"
                Padding="6,4"
                BorderBrush="#2a1d42"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Foreground="#5a4a6e" />
        </Border>

        <!-- Building knowledge base indicator -->
        <Border DockPanel.Dock="Top" Padding="12,16"
                Background="#1a0e30" IsVisible="{Binding IsBuildingKnowledgeBase}">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Building Piece Catalog..."
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#4dbdbd" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding BuildingMessage}"
                           FontSize="11" Foreground="#6a8a8a"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <ProgressBar IsIndeterminate="True" Height="4"
                             Foreground="#4dbdbd" Background="#2a1d42" />
            </StackPanel>
        </Border>

        <!-- Piece List -->
        <ListBox ItemsSource="{Binding PrefabEntries}"
                 SelectedItem="{Binding SelectedPrefab}"
                 FontSize="11"
                 Background="Transparent"
                 IsVisible="{Binding !IsBuildingKnowledgeBase}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PrefabListEntry">
                    <Grid ColumnDefinitions="Auto,*" Margin="2,3"
                          PointerEntered="PrefabItem_PointerEntered"
                          PointerExited="PrefabItem_PointerExited"
                          Background="Transparent">
                        <Panel Grid.Column="0" Width="80" Height="80">
                            <Border Background="#FF0E0A16" CornerRadius="4"
                                    IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}" />
                            <Image Width="80" Height="80" Source="{Binding Thumbnail}" Stretch="Uniform"
                                   IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </Panel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3" Margin="8,0,0,0">
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="#c0e0e0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DetailText}"
                                       Foreground="#5a6a6a"
                                       FontSize="10" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
